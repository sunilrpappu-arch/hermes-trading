HERMES_TRADING_MODE=paper
HERMES_TRADING_I_ACCEPT_RISK=false

# --- Binance API keys (required for live mode) ---
# Create keys at https://www.binance.com/en/my/settings/api-management
# Permissions needed: Enable Spot & Margin Trading
# IP restriction: recommended — whitelist your Railway service IP
# NEVER enable withdrawals on trading keys
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Set to true to use Binance testnet instead of mainnet
HERMES_TRADING_TESTNET=false

# --- Futures config ---
# Leverage (1x = no liquidation risk beyond margin, recommended to start)
HERMES_LEVERAGE=1

# --- Capital config ---
# Total USDT split evenly across all pairs (200 USDT each at 5 pairs)
# Can also set CAPITAL_PER_PAIR_USDT directly to override
CAPITAL_PER_PAIR_USDT=200

# --- Optional data API keys ---
GLASSNODE_API_KEY=
NEWS_API_KEY=
